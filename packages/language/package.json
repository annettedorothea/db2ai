{
    "name": "db-2-ai-dsl-language",
    "description": "The language specific package",
    "version": "0.0.4",
    "type": "module",
    "engines": {
        "node": ">=20.10.0",
        "npm": ">=10.2.3"
    },
    "files": [
        "out",
        "src"
    ],
    "main": "./out/index.js",
    "module": "./out/index.js",
    "exports": {
        ".": {
            "types": "./out/index.d.ts",
            "default": "./out/index.js"
        }
    },
    "typesVersions": {
        "*": {
            ".": [
                "out/index"
            ]
        }
    },
    "scripts": {
        "clean": "shx rm -fr *.tsbuildinfo out",
        "build": "echo 'No build step'",
        "build:clean": "npm run clean && npm run build",
        "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "eslint src test",
        "check": "npm run format:check && npm run typecheck && npm run lint",
        "langium:generate": "langium generate && node ../../scripts/langium-generated-skip-check.mjs",
        "langium:watch": "langium generate --watch",
        "test": "vitest run"
    },
    "dependencies": {
        "langium": "~4.2.0",
        "mysql2": "^3.22.3",
        "pg": "~8.16.0"
    },
    "devDependencies": {
        "@types/pg": "~8.15.0",
        "langium-cli": "~4.2.0",
        "vitest": "~3.1.3"
    }
}
