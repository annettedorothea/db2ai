{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "noEmit": false,
        "declaration": false,
        "rootDir": ".",
        "outDir": ".",
        "types": ["node"]
    },
    "include": ["generated/**/*.ts", "src/hooks/**/*.ts", "src/db/**/*.ts", "src/utils/**/*.ts", "types/**/*.d.ts"],
    "exclude": ["node_modules", "tmp"]
}
