{
    "mcpServers": {
        "sakila": {
            "command": "node",
            "envFile": ".env",
            "args": [
                "./generated/cli/stdio-mcp-server.js",
                "./generated/tools/sakila-tools.js",
                "--auth-env",
                "DB2AI_AUTH_TOKEN",
                "--credential-validation",
                "static",
                "--auth-expected-env",
                "MCP_AUTH_EXPECTED"
            ],
            "env": {
                "SAKILA_DATABASE_URL": "mysql://sakila:p_ssW0rd@localhost:53306/sakila"
            }
        },
        "pagila": {
            "url": "http://127.0.0.1:4853/mcp",
            "headers": {
                "x-api-token": "demo"
            }
        },
        "orders": {
            "url": "http://127.0.0.1:4871/mcp",
            "auth": {
                "CLIENT_ID": "mcp-demo-local"
            }
        },
        "animals": {
            "command": "node",
            "envFile": ".env",
            "args": ["./generated/cli/stdio-mcp-server.js", "./generated/tools/animals-sqlserver-tools.js"],
            "env": {
                "ANIMALS_SQLSERVER_DATABASE_URL": "sqlserver://sa:YourStrong!Passw0rd@localhost:55434/animals?encrypt=true&trustServerCertificate=true"
            }
        }
    }
}
