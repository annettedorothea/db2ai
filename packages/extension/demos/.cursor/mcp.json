{
    "mcpServers": {
        "stdio-db2ai-pagila": {
            "command": "node",
            "envFile": ".env.local",
            "args": [
                "./generated/cli/stdio-mcp-server.js",
                "./generated/tools/pagila-tools.js",
                "--auth-env",
                "DB2AI_AUTH_TOKEN"
            ],
            "env": {
                "PAGILA_DATABASE_URL": "postgresql://postgres:postgres@localhost:55432/pagila"
            }
        },
        "http-db2ai-pagila": {
            "url": "http://127.0.0.1:3853/mcp"
        },
