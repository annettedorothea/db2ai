{
    "mcpServers": {
        "sakila-mysql": {
            "command": "node",
            "envFile": ".env",
            "args": [
                "./generated/db2ai/cli/stdio-mcp-server.js",
                "./generated/db2ai/tools/sakila-mysql-tools.js",
                "--auth-env",
                "DB2AI_AUTH_TOKEN"
            ],
            "env": {
                "SAKILA_MYSQL_DATABASE_URL": "mysql://sakila:p_ssW0rd@localhost:53306/sakila"
            }
        },
        "sakila-mariadb": {
            "command": "node",
            "envFile": ".env",
            "args": ["./generated/db2ai/cli/stdio-mcp-server.js", "./generated/db2ai/tools/sakila-mariadb-tools.js"],
            "env": {
                "SAKILA_MARIADB_DATABASE_URL": "mariadb://sakila:p_ssW0rd@localhost:53306/sakila"
            }
        },
        "pagila-postgresql": {
            "url": "http://127.0.0.1:4853/mcp",
            "headers": {
                "x-api-token": "demo"
            }
        },
        "orders-postgresql": {
            "url": "http://127.0.0.1:4871/mcp",
            "auth": {
                "CLIENT_ID": "mcp-demo-local"
            }
        },
        "animals-sqlserver": {
            "command": "node",
            "envFile": ".env",
            "args": ["./generated/db2ai/cli/stdio-mcp-server.js", "./generated/db2ai/tools/animals-sqlserver-tools.js"],
            "env": {
                "ANIMALS_SQLSERVER_DATABASE_URL": "sqlserver://sa:YourStrong!Passw0rd@localhost:55434/animals?encrypt=true&trustServerCertificate=true"
            }
        },
        "plants-oracle": {
            "command": "node",
            "envFile": ".env",
            "args": ["./generated/db2ai/cli/stdio-mcp-server.js", "./generated/db2ai/tools/plants-oracle-tools.js"],
            "env": {
                "PLANTS_ORACLE_DATABASE_URL": "oracle://plants:PlantsDemo123@localhost:55221/FREEPDB1"
            }
        }
    }
}
