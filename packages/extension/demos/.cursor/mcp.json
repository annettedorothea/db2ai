{
    "mcpServers": {
        "sakila-mysql": {
            "url": "http://127.0.0.1:4852/mcp",
            "headers": {
                "x-api-token": "demo"
            }
        },
        "sakila-mariadb": {
            "command": "node",
            "args": [
                "${workspaceFolder}/generated/db2ai/servers/sakila-mysql-stdio-mcp-server.js",
                "--auth-env",
                "MCP_AUTH_EXPECTED"
            ],
            "envFile": "${workspaceFolder}/.env"
        },
        "pagila-postgresql": {
            "url": "http://127.0.0.1:4853/mcp",
            "headers": {
                "x-api-token": "demo"
            }
        },
        "orders-postgresql": {
            "url": "http://127.0.0.1:4871/mcp",
            "auth": {
                "CLIENT_ID": "mcp-demo-local"
            }
        },
        "animals-sqlserver": {
            "url": "http://127.0.0.1:4855/mcp"
        },
        "plants-oracle": {
            "url": "http://127.0.0.1:4856/mcp"
        }
    }
}
