.env
.env.local

# Emitted next to auth stubs by mistake or local tsc — keep only *.ts in src/auth/
src/auth/**/*.js
src/auth/**/*.js.map
src/auth/**/*.mjs

# tsc emit from build:generated — commit *.ts only under src/hooks and src/utils
src/hooks/**/*.js
src/hooks/**/*.js.map
src/utils/**/*.js
src/utils/**/*.js.map

# tsc emit from build:generated — commit generated/**/*.ts only
generated/**/*.js
generated/**/*.js.map

# codegen build stamp — one file per product, updated on every generate
generated/*/mcp-build-generated-at.ts

tmp/
dist/
.cursor/plans/
