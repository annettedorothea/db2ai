PAGILA_POSTGRESQL_DATABASE_URL=postgresql://postgres:postgres@localhost:55432/pagila
SAKILA_MYSQL_DATABASE_URL=mysql://sakila:p_ssW0rd@localhost:53306/sakila
# Same Sakila Docker DB — mariadb:// scheme for sakila-mariadb.db2ai dialect smoke test
SAKILA_MARIADB_DATABASE_URL=mariadb://sakila:p_ssW0rd@localhost:53306/sakila
ORDERS_POSTGRESQL_DATABASE_URL=postgresql://postgres:postgres@localhost:55433/orders_postgres

# SQL Server animals demo (started by npm run start / db:up:all)
ANIMALS_SQLSERVER_SA_PASSWORD=YourStrong!Passw0rd
ANIMALS_SQLSERVER_HOST_PORT=55434
ANIMALS_SQLSERVER_DATABASE_URL=sqlserver://sa:YourStrong!Passw0rd@localhost:55434/animals?encrypt=true&trustServerCertificate=true

# Oracle plants demo (npm run start / db:up:all; docker login container-registry.oracle.com once)
PLANTS_ORACLE_SYS_PASSWORD=OracleDemo123
PLANTS_ORACLE_HOST_PORT=55221
PLANTS_ORACLE_DATABASE_URL=oracle://plants:PlantsDemo123@localhost:55221/FREEPDB1

MCP_AUTH_HEADER=x-api-token
# Expected MCP header value for pagila-postgresql/sakila-mysql (verify*Credentials in src/auth/db2ai/*-tools/)
MCP_AUTH_EXPECTED=demo
DB2AI_AUTH_TOKEN=demo

# HTTP MCP host: pagila-postgresql
PAGILA_POSTGRESQL_HTTP_PORT=4853

# OAuth IdP + MCP host: orders-postgresql (oidc)
ORDERS_POSTGRESQL_OAUTH_IDP_PORT=4863
ORDERS_POSTGRESQL_OAUTH_IDP_URL=http://127.0.0.1:4863
ORDERS_POSTGRESQL_OAUTH_HTTP_PORT=4871
ORDERS_POSTGRESQL_JWT_SECRET=db2ai-orders-postgresql

# OAuth IdP redirect allowlist — see api2ai oauth-idp/README.md
OAUTH_IDP_REDIRECT_URIS=cursor://anysphere.cursor-mcp/oauth/callback
# OAUTH_IDP_REDIRECT_URIS=cursor://anysphere.cursor-mcp/oauth/callback,http://localhost:3000/oauth/clients/mcp:*
