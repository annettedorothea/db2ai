# Copy to .env via npm run init or npm run start — demo credentials only; do not commit .env.

# Shared — MCP header auth for passthrough DB hosts (pagila-postgresql, sakila-mysql)
MCP_AUTH_HEADER=x-api-token
MCP_AUTH_EXPECTED=demo

# pagila-postgresql — passthrough MCP + PostgreSQL (Docker)
PAGILA_POSTGRESQL_DATABASE_URL=postgresql://postgres:postgres@localhost:55432/pagila
PAGILA_POSTGRESQL_HTTP_PORT=4853

# sakila-mysql — passthrough MCP + MySQL Sakila (Docker)
SAKILA_MYSQL_DATABASE_URL=mysql://sakila:p_ssW0rd@localhost:53306/sakila
SAKILA_MYSQL_HTTP_PORT=4852

# sakila-mariadb — public MCP; same Sakila DB with mariadb:// dialect smoke test
SAKILA_MARIADB_DATABASE_URL=mariadb://sakila:p_ssW0rd@localhost:53306/sakila
SAKILA_MARIADB_HTTP_PORT=4854

# animals-sqlserver — public MCP + SQL Server (npm run start:all / db:up:all)
ANIMALS_SQLSERVER_SA_PASSWORD=YourStrong!Passw0rd
ANIMALS_SQLSERVER_HOST_PORT=55434
ANIMALS_SQLSERVER_DATABASE_URL=sqlserver://sa:YourStrong!Passw0rd@localhost:55434/animals?encrypt=true&trustServerCertificate=true
ANIMALS_SQLSERVER_HTTP_PORT=4855

# plants-oracle — public MCP + Oracle (docker login container-registry.oracle.com once)
PLANTS_ORACLE_SYS_PASSWORD=OracleDemo123
PLANTS_ORACLE_HOST_PORT=55221
PLANTS_ORACLE_DATABASE_URL=oracle://plants:PlantsDemo123@localhost:55221/FREEPDB1
PLANTS_ORACLE_HTTP_PORT=4856

# flight — public MCP + in-memory DuckDB (CSV under flights/)
FLIGHT_HTTP_PORT=4857

# sales-report — public MCP + in-memory DuckDB (messy Excel under sales-report/)
SALES_REPORT_HTTP_PORT=4858

# orders-postgresql — OAuth MCP + PostgreSQL orders DB
ORDERS_POSTGRESQL_DATABASE_URL=postgresql://postgres:postgres@localhost:55433/orders_postgres
ORDERS_POSTGRESQL_OAUTH_IDP_PORT=4863
ORDERS_POSTGRESQL_OAUTH_IDP_URL=http://127.0.0.1:4863
ORDERS_POSTGRESQL_OAUTH_HTTP_PORT=4871
ORDERS_POSTGRESQL_JWT_SECRET=db2ai-orders-postgresql

# OAuth redirect allowlist — Cursor (IDE + CLI loopback) + MCP Inspector (Inspector uses localhost:6274, read-only in UI)
OAUTH_IDP_REDIRECT_URIS=cursor://anysphere.cursor-mcp/oauth/callback,http://localhost:8787/callback,http://localhost:6274/oauth/callback,http://localhost:6274/oauth/callback/debug,http://127.0.0.1:6274/oauth/callback,http://127.0.0.1:6274/oauth/callback/debug

# Browser CORS for oauth HTTP host + demo IdPs (optional — unset reflects request Origin)
# MCP_HTTP_CORS_ORIGIN=http://localhost:6274
