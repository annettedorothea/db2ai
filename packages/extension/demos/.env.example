PAGILA_DATABASE_URL=postgresql://postgres:postgres@localhost:55432/pagila
SAKILA_DATABASE_URL=mysql://sakila:p_ssW0rd@localhost:53306/sakila
ACCESS_DEMO_DATABASE_URL=postgresql://postgres:postgres@localhost:55433/access_demo
# Stateless HTTP MCP — header name for client credential pass-through (JWT sent by MCP client, not here)
MCP_AUTH_HEADER=x-api-token
ACCESS_DEMO_HTTP_PORT=3852
PAGILA_HTTP_PORT=3853
SAKILA_HTTP_PORT=3854
# Stateless HTTP MCP — urls in mcp.json: 3852 access-demo, 3853 pagila, 3854 sakila
# Pagila/Sakila MCP — only for protected tools (e.g. listActors); omit for public-only use
# DB2AI_AUTH_TOKEN=demo
# access-demo — only for protected/checked tools; listProducts (public) works without any token
# alice — customerId alice, role user
# ACCESS_DEMO_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJjdXN0b21lcklkIjoiYWxpY2UiLCJyb2xlIjoidXNlciJ9.W8kJLviah23DKhSJ-gd6LF7phONqmyOqe57WD8sHwFo
# bob — customerId bob, role user
# ACCESS_DEMO_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJjdXN0b21lcklkIjoiYm9iIiwicm9sZSI6InVzZXIifQ.UECZOURyZVt3uXNQvbQX2puJUzkj3cNaHVHOyqcqAR8
# admin — customerId admin, role admin (may read any customerId)
# ACCESS_DEMO_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJjdXN0b21lcklkIjoiYWRtaW4iLCJyb2xlIjoiYWRtaW4ifQ.EuwlIRWo3m_FBSK-z8JFU7cLmkqBj-phk44NuKHGxt4

# access-demo OAuth IDP + oauth-http MCP (oauth-db2ai-access-demo in mcp.json)
ACCESS_DEMO_OAUTH_IDP_PORT=3862
ACCESS_DEMO_OAUTH_IDP_URL=http://127.0.0.1:3862
ACCESS_DEMO_OAUTH_HTTP_PORT=3871
ACCESS_DEMO_JWT_SECRET=db2ai-access-demo
