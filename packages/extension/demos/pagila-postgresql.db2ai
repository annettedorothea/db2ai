database postgres env "PAGILA_POSTGRESQL_DATABASE_URL"

auth

SQL {
    toolName: listFilms
    access: protected
    prepare: true
    intent: "list films from Pagila with pagination"
    query: "SELECT * FROM film LIMIT LEAST(:limit, 100) OFFSET :offset"
    summary: "Paginated film rows"
    params: {
        limit: { description: "max rows per page" example: "100" type: integer }
        offset: { description: "rows to skip" example: "0" type: integer }
    }
    response: '''
        Object with rows (film table columns from SELECT *) and rowCount.
        Use rowCount for pagination; limit is capped at 100 in SQL.
    '''
}

SQL {
    toolName: listActors
    access: protected
    prepare: true
    intent: '''
        List actors from Pagila with pagination.
    '''
    query: "SELECT * FROM actor LIMIT LEAST(:limit, 100) OFFSET :offset"
    summary: "Paginated actor rows"
    params: {
        limit: { description: '''
                Max rows per page.
                SQL caps at 100 via LEAST(:limit, 100).
            '''
            example: "100"
            type: integer 
        }
        offset: { description: "rows to skip" example: "0" type: integer }
    }
    response: '''
        Object with rows (actor table columns from SELECT *) and rowCount.
        Use rowCount for pagination; limit is capped at 100 in SQL.
    '''
}

