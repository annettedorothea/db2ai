{
    "name": "db2ai-examples",
    "private": true,
    "type": "module",
    "scripts": {
        "start": "npm run start:all",
        "start:all": "node ./scripts/start.mjs",
        "start:foreground": "START_FOREGROUND=1 npm run start:all",
        "start:sakila-mysql": "node ./scripts/start-demo.mjs sakila-mysql",
        "start:pagila-postgresql": "node ./scripts/start-demo.mjs pagila-postgresql",
        "start:orders-postgresql": "node ./scripts/start-demo.mjs orders-postgresql",
        "start:animals-sqlserver": "node ./scripts/start-demo.mjs animals-sqlserver",
        "start:plants-oracle": "node ./scripts/start-demo.mjs plants-oracle",
        "demo:kill-all": "LOG_SERVICE_PREFIX=kill-all node ./scripts/kill-all-demos.mjs",
        "db:up:all": "node ./scripts/database/db-up-all.mjs",
        "db:down": "node ./scripts/database/db-down-all.mjs",
        "generate:all": "node ./scripts/generate-all.mjs && npm run format",
        "build:generated": "tsc -p tsconfig.generated.json",
        "test": "vitest run",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "check": "npm run format:check && npm run typecheck && npm run lint"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "jose": "^6.2.3",
        "mysql2": "^3.22.5",
        "mssql": "^11.0.1",
        "oracledb": "^6.10.0",
        "pg": "~8.21.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "~22.19.20",
        "@types/pg": "~8.20.0",
        "eslint": "^10.4.1",
        "prettier": "^3.8.3",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.60.1",
        "vitest": "~4.1.8"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.61.1"
    }
}
