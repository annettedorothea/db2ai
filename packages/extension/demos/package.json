{
    "name": "db2ai-examples",
    "private": true,
    "type": "module",
    "scripts": {
        "start": "npm run start:mcp",
        "start:mcp": "node ./scripts/start-mcp.mjs",
        "start:all": "node ./scripts/start-all.mjs",
        "start:fixtures": "node ./scripts/start-fixtures.mjs",
        "demo:kill-all": "LOG_SERVICE_PREFIX=kill-all node ./scripts/kill-all-demos.mjs",
        "demo:kill-mcp": "LOG_SERVICE_PREFIX=kill-mcp node ./scripts/kill-mcp-hosts.mjs",
        "demo:kill-fixtures": "LOG_SERVICE_PREFIX=kill-fixtures node ./scripts/kill-fixtures.mjs",
        "db:up:all": "node ./scripts/database/db-up-all.mjs",
        "db:down": "node ./scripts/database/db-down-all.mjs",
        "generate:all": "node ./generated/db2ai/scripts/generate-all-vsix.mjs && npm run format",
        "sync:generated-scripts": "node ./scripts/sync-generated-scripts.mjs",
        "build:generated": "node ./generated/db2ai/scripts/ensure-mcp-build-stamp.mjs && tsc -p tsconfig.generated.json",
        "build:mcp": "node ./scripts/build-mcp.mjs",
        "test": "vitest run",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "check": "npm run format:check && npm run typecheck && npm run lint",
        "mcp:inspect": "node ./scripts/mcp-inspect.mjs"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@toolfactory.dev/core": "^1.0.0-rc.8",
        "jose": "^6.2.3",
        "mssql": "^11.0.1",
        "mysql2": "^3.22.5",
        "oracledb": "^6.10.0",
        "pg": "~8.21.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "~22.19.20",
        "@types/pg": "~8.20.0",
        "esbuild": "~0.28.0",
        "eslint": "^10.4.1",
        "prettier": "^3.8.3",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.60.1",
        "vitest": "~4.1.8"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.61.1"
    }
}
