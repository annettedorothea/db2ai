{
    "name": "db2ai-examples",
    "private": true,
    "type": "module",
    "scripts": {
        "db:pagila:up": "docker compose up -d --wait pagila",
        "db:sakila:up": "docker compose up -d --wait sakila",
        "db:access-demo:up": "docker compose up -d --wait access-demo",
        "db:access-demo:reset": "docker rm -f db2ai-access-demo 2>/dev/null || true; npm run db:access-demo:up",
        "db:up:all": "docker compose up -d --wait pagila sakila access-demo",
        "db:down": "docker compose down",
        "db:pagila:reset": "docker rm -f db2ai-pagila 2>/dev/null || true; npm run db:pagila:up",
        "db:sakila:reset": "docker rm -f db2ai-sakila 2>/dev/null || true; npm run db:sakila:up",
        "db:pagila:psql": "docker compose exec pagila psql -U postgres -d pagila",
        "db:sakila:mysql": "docker compose exec sakila mysql -u sakila -pp_ssW0rd sakila",
        "db:up": "npm run db:pagila:up",
        "db:reset": "npm run db:pagila:reset",
        "db:psql": "npm run db:pagila:psql",
        "db:mysql": "npm run db:sakila:mysql",
        "generate:pagila": "node ./scripts/generate.mjs pagila.db2ai generated/tools/pagila-tools.ts",
        "generate:sakila": "node ./scripts/generate.mjs sakila.db2ai generated/tools/sakila-tools.ts",
        "generate:access-demo": "node ./scripts/generate.mjs access-demo.db2ai generated/tools/access-demo-tools.ts",
        "generate:all": "node ./scripts/generate-all.mjs",
        "build:generated": "tsc -p tsconfig.generated.json",
        "test": "vitest run",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "check": "npm run format:check && npm run typecheck && npm run lint"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "mysql2": "^3.22.3",
        "pg": "~8.16.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@core2ai/core": "0.0.5",
        "@eslint/js": "^10.0.1",
        "@types/node": "~20.17.48",
        "eslint": "^10.4.0",
        "prettier": "^3.8.3",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.59.4",
        "vitest": "~3.1.3"
    }
}
