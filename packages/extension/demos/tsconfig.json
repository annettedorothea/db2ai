{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "noEmit": true,
        "rootDir": ".",
        "types": ["node"]
    },
    "include": [
        "generated/**/*.ts",
        "src/hooks/**/*.ts",
        "src/utils/**/*.ts",
        "test/**/*.ts",
        "vitest.config.ts",
        "types/**/*.d.ts"
    ],
    "exclude": ["node_modules", "tmp"]
}
