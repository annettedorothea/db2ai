database postgres env "PAGILA_DATABASE_URL"

auth

SQL {
    toolName: listFilms
    access: public
    intent: "list films from Pagila with pagination"
    query: "SELECT * FROM film LIMIT LEAST(:limit, 500) OFFSET :offset"
    summary: "Paginated film rows"
    params: {
        limit: { description: "max rows per page" example: "100" type: integer }
        offset: { description: "rows to skip" example: "0" type: integer }
    }
}

SQL {
    toolName: listActors
    access: protected
    intent: '''
        List actors from Pagila with pagination.
        Protected: requires DB2AI_AUTH_TOKEN at MCP startup.
    '''
    query: "SELECT * FROM actor LIMIT LEAST(:limit, 500) OFFSET :offset"
    summary: "Paginated actor rows"
    params: {
        limit: { description: '''
                Max rows per page.
                SQL caps at 500 via LEAST(:limit, 500).
            '''
            example: "100"
            type: integer }
        offset: { description: "rows to skip" example: "0" type: integer }
    }
}

