{
    "name": "vscode-db2ai",
    "displayName": "db2ai",
    "description": "Language support and code generation for the .db2ai DSL (PostgreSQL → MCP tools).",
    "version": "0.0.1",
    "publisher": "db2ai",
    "license": "BUSL-1.1",
    "icon": "icon.png",
    "author": {
        "name": "Annette Pohl"
    },
    "type": "module",
    "engines": {
        "vscode": "^1.67.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "db-2-ai-dsl",
                "aliases": [
                    "db2ai-dsl",
                    "db-2-ai-dsl"
                ],
                "extensions": [
                    ".db2ai"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "db-2-ai-dsl",
                "scopeName": "source.db-2-ai-dsl",
                "path": "syntaxes/db-2-ai-dsl.tmLanguage.json"
            }
        ],
        "configurationDefaults": {
            "[db-2-ai-dsl]": {
                "editor.wordBasedSuggestions": "off"
            }
        },
        "commands": [
            {
                "command": "db2ai.generateTools",
                "title": "Generate tool code (.ts + .mjs + MCP host)"
            },
            {
                "command": "db2ai.createDemoWorkspace",
                "title": "db2ai: Create demo workspace (MCP examples)"
            }
        ]
    },
    "activationEvents": [
        "onLanguage:db-2-ai-dsl",
        "onCommand:db2ai.generateTools",
        "onCommand:db2ai.createDemoWorkspace"
    ],
    "main": "./out/extension/main.cjs",
    "scripts": {
        "clean": "shx rm -fr *.tsbuildinfo out syntaxes",
        "vscode:prepublish": "npm run build",
        "build:prepare": "shx mkdir -p ./syntaxes/ && shx cp -f ../language/syntaxes/db-2-ai-dsl.tmLanguage.json ./syntaxes/db-2-ai-dsl.tmLanguage.json",
        "build": "npm run build:prepare && tsc -b tsconfig.json && node esbuild.mjs && node embed-cli-bundle.mjs",
        "build:clean": "npm run clean && npm run build",
        "watch": "npm run build:prepare && npm run embed-cli:onetime && concurrently -n tsc,esbuild -c blue,yellow \"tsc -b tsconfig.json --watch\" \"node esbuild.mjs --watch\"",
        "embed-cli:onetime": "node embed-cli-bundle.mjs",
        "extension:vsix": "npm run langium:generate --prefix ../.. && npm run build --prefix ../.. && shx cp ../../LICENSE LICENSE && npx @vscode/vsce package --allow-missing-repository --no-rewrite-relative-links && shx rm -f LICENSE"
    },
    "dependencies": {
        "db-2-ai-dsl-language": "0.0.1",
        "vscode-languageclient": "~9.0.1",
        "vscode-languageserver": "~9.0.1"
    },
    "devDependencies": {
        "@types/vscode": "~1.67.0",
        "@vscode/vsce": "^3.7.1",
        "concurrently": "~8.2.1",
        "esbuild": "~0.25.5"
    },
    "vsce": {
        "dependencies": false
    }
}
