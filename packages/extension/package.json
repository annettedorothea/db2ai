{
    "name": "vscode-db2ai",
    "displayName": "db2ai",
    "description": "Tool Factory — language support and code generation for the .db2ai DSL (PostgreSQL, MySQL, MariaDB, SQL Server, Oracle → MCP tools).",
    "version": "1.0.1",
    "publisher": "toolfactory-dev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/annettedorothea/db2ai.git"
    },
    "homepage": "https://toolfactory.dev",
    "bugs": "https://github.com/annettedorothea/db2ai/issues",
    "keywords": [
        "mcp",
        "sql",
        "database",
        "cursor",
        "tool factory",
        "code generation",
        "langium"
    ],
    "galleryBanner": {
        "color": "#1e1e2e",
        "theme": "dark"
    },
    "icon": "icon.png",
    "author": {
        "name": "Annette Pohl"
    },
    "type": "module",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "db-2-ai-dsl",
                "aliases": [
                    "db2ai-dsl",
                    "db-2-ai-dsl"
                ],
                "extensions": [
                    ".db2ai"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "db-2-ai-dsl",
                "scopeName": "source.db-2-ai-dsl",
                "path": "syntaxes/db-2-ai-dsl.tmLanguage.json"
            }
        ],
        "configurationDefaults": {
            "[db-2-ai-dsl]": {
                "editor.wordBasedSuggestions": "off"
            }
        },
        "commands": [
            {
                "command": "db2ai.generateTools",
                "title": "Generate tool code (.ts + MCP host)"
            },
            {
                "command": "db2ai.createDemoWorkspace",
                "title": "db2ai: Create demo workspace (MCP examples)"
            }
        ]
    },
    "main": "./out/extension/main.cjs",
    "scripts": {
        "clean": "shx rm -fr *.tsbuildinfo out syntaxes",
        "vscode:prepublish": "npm run build",
        "build:prepare": "shx mkdir -p ./syntaxes/ && shx cp -f ../language/syntaxes/db-2-ai-dsl.tmLanguage.json ./syntaxes/db-2-ai-dsl.tmLanguage.json",
        "build": "npm run build:prepare && tsc -b tsconfig.json && node scripts/esbuild.mjs && node scripts/embed-cli-bundle.mjs && node scripts/verify-demos-bundle.mjs",
        "vsix:prepare": "node scripts/vsix-prepare.mjs",
        "vsix:build": "node scripts/vsix-build.mjs",
        "vsix:release": "node scripts/vsix-release.mjs"
    },
    "dependencies": {
        "@duckdb/node-api": "1.5.4-r.1",
        "db-2-ai-dsl-language": "*",
        "vscode-languageclient": "~9.0.1",
        "vscode-languageserver": "~9.0.1"
    },
    "devDependencies": {
        "@types/vscode": "~1.75.0",
        "@vscode/vsce": "^3.9.2",
        "esbuild": "~0.28.0"
    },
    "vsce": {
        "dependencies": false
    }
}
