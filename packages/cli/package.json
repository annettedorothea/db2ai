{
    "name": "db-2-ai-dsl-cli",
    "description": "CLI for db2ai DSL (parse / validate / generate / smoke)",
    "version": "0.0.2",
    "type": "module",
    "engines": {
        "node": ">=20.10.0",
        "npm": ">=10.2.3"
    },
    "files": [
        "bin",
        "out",
        "resources",
        "src",
        "test"
    ],
    "bin": {
        "db-2-ai-dsl-cli": "./bin/cli.js"
    },
    "scripts": {
        "clean": "shx rm -fr *.tsbuildinfo out",
        "build": "echo 'No build step'",
        "build:clean": "npm run clean && npm run build",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@core2ai/core": "file:../../../core2ai",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "chalk": "~5.3.0",
        "commander": "~11.1.0",
        "db-2-ai-dsl-language": "*",
        "mysql2": "^3.22.3",
        "pg": "~8.16.0",
        "prettier": "^3.8.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "vitest": "~3.1.3"
    }
}
