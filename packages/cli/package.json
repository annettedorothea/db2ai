{
    "name": "db-2-ai-dsl-cli",
    "description": "CLI for db2ai DSL (parse / validate / generate / smoke)",
    "version": "0.0.4",
    "type": "module",
    "engines": {
        "node": ">=20.10.0",
        "npm": ">=10.2.3"
    },
    "files": [
        "bin",
        "out",
        "resources",
        "src",
        "test"
    ],
    "bin": {
        "db-2-ai-dsl-cli": "./bin/cli.js"
    },
    "scripts": {
        "clean": "shx rm -fr *.tsbuildinfo out",
        "build": "echo 'No build step'",
        "build:clean": "npm run clean && npm run build",
        "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "eslint src test",
        "check": "npm run format:check && npm run typecheck && npm run lint",
        "test": "vitest run"
    },
    "dependencies": {
        "@core2ai/core": "0.0.5",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "chalk": "~5.3.0",
        "commander": "~11.1.0",
        "db-2-ai-dsl-language": "*",
        "mysql2": "^3.22.3",
        "pg": "~8.16.0",
        "prettier": "^3.8.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "vitest": "~3.1.3"
    }
}
