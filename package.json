{
    "name": "db-2-ai-dsl-workspace",
    "description": "Langium workspace for db2ai — relational DB to MCP tools",
    "version": "0.0.2",
    "license": "BUSL-1.1",
    "type": "module",
    "private": true,
    "scripts": {
        "clean": "npm run clean --workspaces",
        "postinstall": "node scripts/install-git-hooks.mjs",
        "install:hooks": "node scripts/install-git-hooks.mjs",
        "install:github-https": "node scripts/npm-install-github-https.mjs",
        "install:demos": "node scripts/npm-install-github-https.mjs --prefix packages/extension/demos",
        "core2ai:pin": "node scripts/run-core2ai-script.mjs print-core2ai-pin.mjs",
        "core2ai:link-mode": "node scripts/run-core2ai-script.mjs detect-core2ai-link-mode.mjs",
        "core2ai:use-local": "node scripts/run-core2ai-script.mjs use-local-core2ai.mjs",
        "core2ai:use-pin": "node scripts/run-core2ai-script.mjs refresh-core2ai-pin.mjs",
        "core2ai:apply-pin": "node scripts/run-core2ai-script.mjs apply-core2ai-pin.mjs",
        "core2ai:refresh-pin": "node scripts/run-core2ai-script.mjs refresh-core2ai-pin.mjs",
        "core2ai:check-staged-pin": "node scripts/run-core2ai-script.mjs check-staged-core2ai-pin.mjs",
        "core2ai:check-push-pin": "node scripts/run-core2ai-script.mjs check-push-core2ai-pin.mjs",
        "core2ai:check-resolved": "node scripts/run-core2ai-script.mjs check-resolved-core2ai-link.mjs",
        "watch": "tsc -b tsconfig.build.json --watch",
        "build": "tsc -b tsconfig.build.json && npm run bundle:mcp-runtime && npm run build --workspaces",
        "bundle:mcp-runtime": "esbuild @core2ai/core/mcp-host/standalone-entry --bundle --platform=node --format=esm --banner:js=\"#!/usr/bin/env node\" --outfile=packages/cli/resources/mcp-serve-emitted.mjs --external:@modelcontextprotocol/sdk --external:zod --external:pg",
        "build:clean": "npm run clean && npm run build",
        "extension:vsix": "npm run --workspace packages/extension extension:vsix",
        "extension:release:vsix": "NAME=$(node -p \"require('./packages/extension/package.json').name\") && VERSION=$(node -p \"require('./packages/extension/package.json').version\") && gh release create \"${NAME}-${VERSION}\" \"packages/extension/${NAME}-${VERSION}.vsix\" --title \"${NAME} ${VERSION}\" --notes \"Internal test build of the db2ai Cursor/VS Code extension.\" --prerelease",
        "release:verify": "npm run test && npm run check",
        "release:package": "npm run extension:vsix",
        "release:vsix": "npm run release:verify && npm run release:package && npm run extension:release:vsix",
        "version:patch": "npm version patch --workspace packages/extension --no-git-tag-version",
        "version:minor": "npm version minor --workspace packages/extension --no-git-tag-version",
        "version:major": "npm version major --workspace packages/extension --no-git-tag-version",
        "langium:generate": "npm run --workspace packages/language langium:generate",
        "langium:watch": "npm run --workspace packages/language langium:watch",
        "generate:pagila": "npm run generate:pagila --prefix ./packages/extension/demos",
        "generate:sakila": "npm run generate:sakila --prefix ./packages/extension/demos",
        "generate:access-demo": "npm run generate:access-demo --prefix ./packages/extension/demos",
        "generate:all": "npm run generate:all --prefix ./packages/extension/demos",
        "test": "npm run langium:generate && npm run build && npm run test:unit && npm run test:e2e",
        "test:unit": "npm run --workspace packages/language test && npm run --workspace packages/cli test",
        "test:e2e": "npm run test:mcp:pagila && npm run test:mcp:sakila && npm run test:mcp:access-demo",
        "test:coverage": "npm run --workspace packages/language test:coverage && npm run --workspace packages/cli test:coverage",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc -b tsconfig.build.json --pretty false",
        "typecheck:generated": "tsc -p packages/extension/demos/tsconfig.generated.json --pretty false",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "lint:generated": "eslint packages/extension/demos/generated/tools/**/*.ts",
        "check:generated": "npm run lint:generated && npm run typecheck:generated",
        "check": "npm run format:check && npm run typecheck && npm run lint && npm run check:generated",
        "test:smoke:pagila": "node ./packages/cli/bin/cli.js smoke-generated ./packages/extension/demos/generated/tools/pagila-tools.mjs listFilms",
        "test:smoke:access-demo": "node ./packages/cli/bin/cli.js smoke-generated ./packages/extension/demos/generated/tools/access-demo-tools.mjs listProducts",
        "test:mcp:pagila": "node ./packages/cli/out/test/e2e/mcp-smoke-pagila.js",
        "test:mcp:sakila": "node ./packages/cli/out/test/e2e/mcp-smoke-sakila.js",
        "test:mcp:access-demo": "node ./packages/cli/out/test/e2e/mcp-smoke-access-demo.js"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "~20.17.48",
        "@vitest/coverage-v8": "^3.1.4",
        "esbuild": "^0.25.12",
        "eslint": "^10.4.0",
        "prettier": "^3.8.3",
        "shx": "~0.4.0",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.59.4"
    },
    "workspaces": [
        "packages/language",
        "packages/cli",
        "packages/extension"
    ]
}
