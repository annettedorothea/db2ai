{
    "name": "db-2-ai-dsl-workspace",
    "description": "Langium workspace for db2ai — relational DB to MCP tools",
    "version": "0.0.1",
    "license": "MIT",
    "type": "module",
    "private": true,
    "scripts": {
        "clean": "npm run clean --workspaces",
        "postinstall": "node scripts/install-git-hooks.mjs",
        "install:hooks": "node scripts/install-git-hooks.mjs",
        "install:github-https": "node scripts/npm-install-github-https.mjs",
        "watch": "tsc -b tsconfig.build.json --watch",
        "build": "tsc -b tsconfig.build.json && npm run bundle:mcp-runtime && npm run build --workspaces",
        "bundle:mcp-runtime": "esbuild @core2ai/core/mcp-host/standalone-entry --bundle --platform=node --format=esm --banner:js=\"#!/usr/bin/env node\" --outfile=packages/cli/resources/mcp-serve-emitted.mjs --external:@modelcontextprotocol/sdk --external:zod --external:pg",
        "build:clean": "npm run clean && npm run build",
        "langium:generate": "npm run --workspace packages/language langium:generate",
        "langium:watch": "npm run --workspace packages/language langium:watch",
        "generate:pagila": "npm run generate:pagila --prefix ./packages/extension/demos",
        "generate:sakila": "npm run generate:sakila --prefix ./packages/extension/demos",
        "test": "npm run langium:generate && npm run build && npm run test:unit && npm run test:e2e",
        "test:unit": "npm run --workspace packages/language test && npm run --workspace packages/cli test",
        "test:e2e": "npm run test:mcp:pagila && npm run test:mcp:sakila",
        "test:coverage": "npm run --workspace packages/language test:coverage && npm run --workspace packages/cli test:coverage",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc -b tsconfig.build.json --pretty false",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "check": "npm run format:check && npm run typecheck && npm run lint",
        "test:smoke:pagila": "node ./packages/cli/bin/cli.js smoke-generated ./packages/extension/demos/generated/tools/pagila-tools.mjs listFilms",
        "test:mcp:pagila": "node ./packages/cli/out/test/e2e/mcp-smoke-pagila.js",
        "test:mcp:sakila": "node ./packages/cli/out/test/e2e/mcp-smoke-sakila.js"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "~20.17.48",
        "@vitest/coverage-v8": "^3.1.4",
        "esbuild": "^0.25.12",
        "eslint": "^10.4.0",
        "prettier": "^3.8.3",
        "shx": "~0.4.0",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.59.4"
    },
    "workspaces": [
        "packages/language",
        "packages/cli",
        "packages/extension"
    ]
}
